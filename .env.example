# ── REQUIRED ──────────────────────────────────────
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── OPTIONAL (have defaults) ─────────────────────
# CC Next.js app URL — only needed when tools call CC API (Phase 2+)
# CC_API_URL=https://krep.vercel/app

# Gemini model for Live API audio
# GEMINI_MODEL=gemini-2.5-flash-native-audio-latest

# Voice persona (Kore = professional, clear)
# VOICE_NAME=Kore

# Server port (Cloud Run uses 8080)
# PORT=8080
